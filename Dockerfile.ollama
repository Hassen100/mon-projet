FROM ollama/ollama:latest

# Expose API port
EXPOSE 11434

# Set environment (Render will override with env vars if needed)
ENV OLLAMA_HOST=0.0.0.0:11434

# Pull orca-mini model during build
# Note: This can take a while (~2.5GB download)
# For faster builds initially, you can comment this out and manually pull via curl after deploy
RUN ollama pull orca-mini || true

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:11434/api/tags || exit 1

# Start Ollama server
CMD ["ollama", "serve"]
