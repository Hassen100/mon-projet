# ========================================
# DATABASE CONFIGURATION
# ========================================
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_DATABASE=backend

# ========================================
# DJANGO SETTINGS
# ========================================
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=django-insecure-seo-dashboard-dev-key
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# ========================================
# CORS SETTINGS
# ========================================
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# ========================================
# GOOGLE ANALYTICS CONFIGURATION
# ========================================
# ÉTAPE 1: Trouvez votre GA4 Property ID
# Allez sur: https://analytics.google.com
# Sélectionnez votre propriété → Admin → Property Settings → Property ID
GA_PROPERTY_ID=VOTRE_GA4_PROPERTY_ID_ICI

# ÉTAPE 2: Collez votre JSON de service account Google Analytics
# Comment l'obtenir:
#   1. Allez sur: https://console.cloud.google.com
#   2. APIs et services → Identifiants
#   3. + CRÉER DES IDENTIFIANTS → Compte de service
#   4. Créez une clé → JSON
#   5. Copiez TOUT le JSON (type, project_id, private_key_id, private_key, 
#      client_email, client_id, auth_uri, token_uri, etc.)
GA_CREDENTIALS_JSON=REMPLACEZ_PAR_VOTRE_JSON_COMPLET

# ========================================
# GOOGLE SEARCH CONSOLE CONFIGURATION
# ========================================
# ÉTAPE 1: Entrez votre domaine (obligatoire)
# Exemple: https://monsite.com/ ou https://www.monsite.com/
GSC_SITE_URL=https://VOTRE_DOMAINE_ICI/

# ÉTAPE 2: Collez votre JSON de service account Google Search Console
# Même processus que Google Analytics
# IMPORTANT: Peut être le même service account que GA ou un nouveau
# Collez le JSON COMPLET (type, project_id, private_key_id, private_key, 
# client_email, client_id, auth_uri, token_uri, etc.)
GSC_CREDENTIALS_JSON=REMPLACEZ_PAR_VOTRE_JSON_COMPLET

# ========================================
# AUTRES PARAMÈTRES (optionnel)
# ========================================
ENABLE_CREATE_ADMIN_PAGE=True
CSRF_TRUSTED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

